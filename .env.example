# ML Service Environment Variables

# HuggingFace Token (REQUIRED for Inference API)
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# API Configuration
USE_HF_INFERENCE_API=True
MODEL_NAME=msmaje/Quantizedphdhatamodel
HF_API_ENDPOINT=https://api-inference.huggingface.co/models/msmaje/Quantizedphdhatamodel

# Server Configuration
HOST=0.0.0.0
PORT=5000
WORKERS=1
RELOAD=False

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://hatafrontend.vercel.app

# Explainability Settings
LIME_NUM_SAMPLES=100
LIME_NUM_FEATURES=10

# Logging
LOG_LEVEL=INFO

# For Render Deployment:
# 1. Go to your Render dashboard
# 2. Select your ML service
# 3. Go to Environment tab
# 4. Add HF_TOKEN with your actual token
# 5. Redeploy the service

